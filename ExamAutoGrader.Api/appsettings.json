{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.EntityFrameworkCore": "Debug",
      "Microsoft.EntityFrameworkCore.Database.Command": "Debug",
      "Microsoft.EntityFrameworkCore.Database.Connection": "Debug",
      "Microsoft.EntityFrameworkCore.Infrastructure": "Debug",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss ",
        "UseUtcTimestamp": true
      }
    },
    "File": {
      "Path": "logs/examautograder-.log",
      "Append": true,
      "FileSizeLimitBytes": 10485760,
      "MaxRollingFiles": 5
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=examautograder;Uid=root;Pwd=123456;Port=3306;Charset=utf8mb4;"
  },
  "DashScope": {
    "ApiKey": "sk-ad0c46fccf434467b9fcdc1da5f248e6",
    "ApiBaseUrl": "https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation",
    "Model": "qwen-turbo",
    "EmbeddingModel": "text-embedding-v2"
  },
  "OCR": {
    "Baidu": {
      "ApiKey": "4ZU85lfX15QASABAncTe6UBz",
      "SecretKey": "d3USY8rx394GDNYxKL09EATei4FyuoHN"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "exam-auto-grader",
    "Topics": {
      "GradingRequests": "grading-requests",
      "GradingResults": "grading-results"
    }
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "ExamAutoGrader:"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:8080",
      "https://examautograder.com"
    ]
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "Window": 60,
    "ReplenishmentPeriod": 60,
    "QueueLimit": 10
  },
  "FileUpload": {
    "MaxFileSize": 5242880,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".bmp", ".gif" ],
    "UploadPath": "wwwroot/uploads"
  },
  "Prometheus": {
    "Enabled": true,
    "MetricsPath": "/metrics"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/examautograder-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}